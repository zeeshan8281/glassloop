# Copy to .env for local runs. In production these are EigenCompute encrypted
# secrets (deploy.env), decryptable only inside the attested TEE.

# LLM access — routed through OpenRouter (OpenAI-compatible)
OPENROUTER_API_KEY=sk-or-v1-...

# Result signing — the enclave derives an Ed25519 key from this seed and signs
# every result; the frontend pins the matching pubkey
SIGNING_SEED=<openssl rand -hex 32>

# Optional overrides (defaults shown):
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# WORKER_MODEL=anthropic/claude-sonnet-4.6
# JUDGE_MODEL=anthropic/claude-opus-4.8
# ORCH_MODEL=<defaults to JUDGE_MODEL>
# MAX_ROUNDS=6                # single-loop round cap
# STAGE_MAX_ROUNDS=4          # rounds per pipeline stage
# AGENTIC_MAX_STEPS=10        # orchestrator step cap
# PASS_THRESHOLD=0.85         # judge score needed to clear a gate
# NO_PROGRESS_PATIENCE=2      # stop after K non-improving rounds
# MAX_USD=1.50                # per-run spend ceiling (estimate)
# PORT=8080
